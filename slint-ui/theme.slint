// theme.slint — design tokens, shared types, and icon path data.
// Mirrors the HTML mockup. The Rust side flips `Theme.dark` (theme arrives as a
// parameter) and sets `Theme.accent`; every color derives from those two.

export enum AppState {
    idle,         // ready to record
    recording,    // capturing mic
    downloading,  // auto-downloading model
    transcribing, // Whisper working
    diarizing,    // speaker diarization working
    result,       // transcript ready
}

export struct ModelItem {
    id: string,
    name: string,
    size: string,
    note: string,
    speed: int,        // 1..4
    quality: int,      // 1..4
    installed: bool,
    selected: bool,
    downloading: bool,
    progress: float,        // 0..1
    progress-label: string, // "720 MB / 1,5 GB"
}

export global Theme {
    // ---- inputs (set from Rust) ----
    in property <bool> dark: false;
    in property <color> accent: #e8590c;

    // ---- derived palette ----
    out property <color> rec: #e5484d;
    out property <color> rec-soft: dark ? #4a2a2c : #fbe9ea;
    out property <color> done: #16a34a;

    out property <color> bg:        dark ? #232220 : #f7f6f4;
    out property <color> surface:   dark ? #2c2b28 : #ffffff;
    out property <color> surface2:  dark ? #353330 : #f1f0ed;
    out property <color> text:      dark ? #ededea : #36322d;
    out property <color> muted:     dark ? #9e9a93 : #7d776f;
    out property <color> faint:     dark ? #6f6b64 : #a8a39b;
    out property <color> border:    dark ? #423f3b : #e6e3df;
    out property <color> border2:   dark ? #3a3835 : #eeece8;
    out property <color> tbar:      dark ? #2a2926 : #efeeeb;
    out property <color> accent-soft: accent.transparentize(dark ? 0.78 : 0.86);

    out property <length> radius: 12px;
    out property <string> ui-font: "IBM Plex Sans";
    out property <string> mono-font: "IBM Plex Mono";
}

